@startuml Skill Management Flow
!theme spacelab
!option handwritten true

skinparam backgroundColor #f8f9fa
skinparam DefaultFontColor #000000
skinparam textFontColor #000000
skinparam classFontColor #000000
skinparam sequenceActorFontColor #000000
skinparam sequenceParticipantFontColor #000000
skinparam sequenceArrowFontColor #000000
skinparam noteFontColor #000000
skinparam classBorderColor #4285F4
skinparam arrowColor #4285F4

actor User
participant "Gemini CLI" as cli
database "Settings (JSON)" as settings
participant "Skill Registry" as registry

User -> cli: /skills enable <name>
activate cli

cli -> settings: Update "enabled" status
activate settings
settings --> cli: Success
deactivate settings

cli -> registry: Load Skill Assets
activate registry
registry --> cli: Skill Loaded
deactivate registry

cli --> User: "Skill <name> enabled successfully"
deactivate cli

note over User, cli
  Disabling follows the same flow,
  but unloads the skill assets.
end note

footer Co-authored by kiquetal
@enduml
